#!/bin/bash
set -e

echo "Updating package lists..."
sudo apt update

echo "Installing X11 base..."
sudo apt -y install \
xserver-xorg \
xinit \

echo "Installing GNOME core..."
sudo apt -y install \
gnome-session \
gnome-shell \
gnome-control-center \
gnome-tweaks \
gnome-terminal \
nautilus \

echo "Installing desktop tools..."
sudo apt -y install \
firefox-esr \
brightnessctl \
fonts-inconsolata \

echo "Installing audio stack..."
sudo apt -y install \
pipewire \
pipewire-pulse \
wireplumber

echo "Installing network management..."
sudo apt -y install \
network-manager \

echo "Installing power management..."
sudo apt -y install \
tlp

echo "Applying GNOME system defaults..."
sudo mkdir -p /etc/dconf/db/local.d
sudo tee /etc/dconf/db/local.d/00-gnome-defaults > /dev/null << 'EOF'
[org/gnome/desktop/interface]
color-scheme='prefer-dark'
gtk-theme='Adwaita-dark'
monospace-font-name='Inconsolata 11'
font-name='Cantarell 11'

[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'

[org/gnome/desktop/screensaver]
lock-delay=uint32 0

[org/gnome/desktop/session]
idle-delay=uint32 300
EOF
sudo dconf update

echo "Done. Run 'startx' to launch GNOME."
