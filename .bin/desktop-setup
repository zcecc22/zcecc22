#!/bin/bash

DOTS="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

sudo apt update

# X11 base
sudo apt -y install \
xserver-xorg \
xinit \
xclip \
xautolock

# Suckless build dependencies
sudo apt -y install \
build-essential \
libx11-dev \
libxft-dev \
libxinerama-dev \
libxss-dev

# Desktop tools
sudo apt -y install \
alacritty \
dmenu \
dunst \
firefox-esr \
brightnessctl \
fonts-inconsolata

# Audio
sudo apt -y install \
pipewire \
pipewire-pulse \
wireplumber

# Network
sudo apt -y install \
ifupdown2 \
wpasupplicant

# Power management (from trixie-backports)
sudo apt -y -t trixie-backports install \
tlp \
tlp-rdw

# Build suckless tools and place binaries in .bin/
for tool in .dwm .slock .slstatus; do
    make -C "$DOTS/$tool"
done
mv "$DOTS/.dwm/dwm"            "$DOTS/.bin/"
mv "$DOTS/.slock/slock"        "$DOTS/.bin/"
mv "$DOTS/.slstatus/slstatus"  "$DOTS/.bin/"
sudo chown root:root "$DOTS/.bin/slock"
sudo chmod u+s       "$DOTS/.bin/slock"
