#!/bin/bash
set -e

DOTS="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "Updating package lists..."
sudo apt update

echo "Installing X11 base..."
sudo apt -y install \
xserver-xorg \
xinit \
xinput \
xclip

echo "Installing suckless build dependencies..."
sudo apt -y install \
build-essential \
libx11-dev \
libxft-dev \
libxinerama-dev \
libxss-dev

echo "Installing desktop tools..."
sudo apt -y install \
dmenu \
dunst \
firefox-esr \
brightnessctl \
fonts-inconsolata \
fonts-font-awesome

echo "Installing audio stack..."
sudo apt -y install \
pipewire \
pipewire-pulse \
wireplumber

echo "Installing power management..."
sudo apt -y install \
tlp

echo "Building suckless tools..."
for tool in .dwm .slstatus .st; do
    make -C "$DOTS/$tool"
done
mv "$DOTS/.dwm/dwm"            "$DOTS/.bin/"
mv "$DOTS/.slstatus/slstatus"  "$DOTS/.bin/"
mv "$DOTS/.st/st"              "$DOTS/.bin/"
for tool in .dwm .slstatus .st; do
    make -C "$DOTS/$tool" clean
done

echo "Done."
