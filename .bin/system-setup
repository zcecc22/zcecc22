#!/bin/bash
set -e

DOTS="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MOUNT="/mnt"

# --- Validate ---
[[ $EUID -eq 0 ]] || { echo "Error: run as root"; exit 1; }
[[ -n "${1:-}" ]] || { echo "Usage: $0 <disk>  (e.g. /dev/sda or /dev/nvme0n1)"; exit 1; }
[[ -b "$1" ]] || { echo "Error: $1 is not a block device"; exit 1; }

DISK="$1"

for cmd in sgdisk debootstrap rsync mkfs.fat mkfs.ext4; do
    command -v "$cmd" &>/dev/null || { echo "Error: $cmd not found (install: gdisk debootstrap rsync dosfstools e2fsprogs)"; exit 1; }
done

# --- Confirm ---
echo "Target disk: $DISK"
lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL "$DISK"
echo
read -rp "This will DESTROY all data on $DISK. Type YES to continue: " confirm
[[ "$confirm" == "YES" ]] || { echo "Aborted."; exit 1; }

HOSTNAME="$(tr -dc 'a-z0-9' < /dev/urandom | head -c 8)"
echo "Hostname: $HOSTNAME"

# --- Cleanup trap ---
cleanup() {
    for fs in dev/pts dev proc sys; do
        mountpoint -q "$MOUNT/$fs" 2>/dev/null && umount "$MOUNT/$fs" || true
    done
    mountpoint -q "$MOUNT/boot" 2>/dev/null && umount "$MOUNT/boot" || true
    mountpoint -q "$MOUNT/home" 2>/dev/null && umount "$MOUNT/home" || true
    mountpoint -q "$MOUNT"      2>/dev/null && umount "$MOUNT"      || true
}
trap cleanup EXIT

# --- Partition ---
echo "Partitioning $DISK..."
sgdisk --zap-all "$DISK"
sgdisk -n 1:0:+128M -t 1:ef00 -c 1:ESP  "$DISK"
sgdisk -n 2:0:+32G  -t 2:8300 -c 2:ROOT "$DISK"
sgdisk -n 3:0:0     -t 3:8300 -c 3:HOME "$DISK"
partprobe "$DISK"
udevadm settle

if [[ "$DISK" =~ nvme|mmcblk ]]; then
    ESP_DEV="${DISK}p1"
    ROOT_DEV="${DISK}p2"
    HOME_DEV="${DISK}p3"
else
    ESP_DEV="${DISK}1"
    ROOT_DEV="${DISK}2"
    HOME_DEV="${DISK}3"
fi

# --- Format ---
echo "Formatting partitions..."
mkfs.fat  -F32 -n ESP  "$ESP_DEV"
mkfs.ext4 -F   -L ROOT "$ROOT_DEV"
mkfs.ext4 -F   -L HOME "$HOME_DEV"

# --- Mount ---
echo "Mounting..."
mount -o noatime,nodiratime,discard "$ROOT_DEV" "$MOUNT"
mkdir -p "$MOUNT/boot" "$MOUNT/home"
mount "$ESP_DEV" "$MOUNT/boot"
mount -o noatime,nodiratime,discard "$HOME_DEV" "$MOUNT/home"

# --- Debootstrap ---
echo "Running debootstrap (this takes a while)..."
debootstrap --arch=amd64 stable "$MOUNT" https://deb.debian.org/debian

# --- fstab ---
echo "Writing fstab..."
cat > "$MOUNT/etc/fstab" << 'FSTAB'
LABEL=ROOT  /       ext4  noatime,nodiratime,discard  0 1
LABEL=HOME  /home   ext4  noatime,nodiratime,discard  0 2
LABEL=ESP   /boot   vfat  umask=0077,noatime          0 2
FSTAB

# --- Bind mounts for chroot ---
for fs in dev proc sys; do
    mount --bind "/$fs" "$MOUNT/$fs"
done
mount --bind /dev/pts "$MOUNT/dev/pts"

# --- Chroot setup ---
echo "Configuring system..."
cat > "$MOUNT/tmp/setup.sh" << EOF
#!/bin/bash
set -e

echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts << 'HOSTS'
127.0.0.1  localhost
127.0.1.1  $HOSTNAME
::1        localhost ip6-localhost ip6-loopback
HOSTS

ln -sf /usr/share/zoneinfo/CET /etc/localtime

cat > /etc/apt/sources.list << 'SOURCES'
deb https://deb.debian.org/debian stable main contrib non-free non-free-firmware
deb https://deb.debian.org/debian-security stable-security main contrib non-free non-free-firmware
deb https://deb.debian.org/debian stable-updates main contrib non-free non-free-firmware
SOURCES

apt-get update
apt-get -y install locales-all systemd-boot efibootmgr

echo "LANG=en_US.UTF-8" > /etc/locale.conf

bootctl install

cat > /boot/loader/loader.conf << 'LOADER'
default @saved
timeout 3
console-mode max
LOADER

apt-get -y install linux-image-amd64

groupadd -g 1000 zcecc22
useradd -u 1000 -g 1000 -M -d /home/zcecc22 -s /bin/bash zcecc22
passwd -d root
passwd -d zcecc22

rm /tmp/setup.sh
EOF

chroot "$MOUNT" /bin/bash /tmp/setup.sh

# --- Copy dotfiles ---
echo "Copying dotfiles to /home/zcecc22..."
rsync -a --chown=1000:1000 "$DOTS/" "$MOUNT/home/zcecc22/"

# --- Network skeleton ---
cat > "$MOUNT/etc/network/interfaces" << 'IFACES'
source /etc/network/interfaces.d/*

auto lo
iface lo inet loopback
IFACES

echo
echo "Done."
echo "  Hostname : $HOSTNAME"
echo "  Disk     : $DISK"
echo "Boot from $DISK (systemd-boot, select Debian)."
